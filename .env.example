# ──────────────────────────────────────────
# HA 대시보드 환경 변수 예시
# 이 파일을 .env 로 복사한 뒤 실제 값으로 채우세요.
# .env 는 절대 git에 커밋하지 마세요.
# ──────────────────────────────────────────

# PostgreSQL 연결 문자열
# 로컬: postgresql+asyncpg://postgres:<비밀번호>@localhost:5432/365dash
# Railway: 자동 주입됨 (설정 불필요)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/365dash

# JWT 서명 비밀키 (랜덤 32자 이상 권장)
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret

# JWT 만료 시간 (분)
JWT_EXPIRE_MINUTES=480

# 로컬 개발 시 CORS 허용 오리진 (쉼표 구분)
# 프로덕션(단일 서비스)에서는 불필요 — 빈 값으로 두면 CORS 미적용
CORS_ORIGINS=http://localhost:5173
